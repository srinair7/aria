# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram (optional)
# TELEGRAM_TOKEN=your_bot_token_here
# TELEGRAM_ALLOWED_IDS=123456789   # your Telegram user ID (get from @userinfobot)

# Optional — Google Custom Search (for web_search tool)
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_CX=your_custom_search_engine_id_here

# Optional — ElevenLabs TTS
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here

# ARIA Settings (defaults shown)
# ARIA_MODEL=claude-sonnet-4-6
# ARIA_DB_PATH=./data/aria.db
# ARIA_MEMORY_WINDOW=20
# ARIA_VOICE_MODEL=small        # whisper model: tiny/base/small/medium/large
# ARIA_TTS_BACKEND=auto          # auto | say | pyttsx3 | elevenlabs
# ARIA_SAY_VOICE=Samantha        # macOS voice name (run `aria voices` to list)
# ARIA_SAY_RATE=180              # speaking rate in words/min (default: ~175)
# ARIA_HOST=0.0.0.0
# ARIA_PORT=8000
